{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monel Gateway",
  "version": "0.1.0",
  "identifier": "com.monel.gateway",
  "build": {
    "beforeDevCommand": "",
    "frontendDist": "../ui",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monel Gateway",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
